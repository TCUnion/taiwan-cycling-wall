/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://connect.facebook.net https://accounts.google.com https://static.cloudflareinsights.com https://*.googletagmanager.com https://*.google-analytics.com https://fonts.googleapis.com https://fonts.gstatic.com https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://unpkg.com https://tdx.transportdata.tw https://ridewithgps.com https://strava-embeds.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com https://unpkg.com; font-src 'self' data: https://fonts.gstatic.com https://r2cdn.perplexity.ai; img-src 'self' data: https:; connect-src 'self' https://*.criterium.tw https://*.supabase.co https://*.zeabur.app https://*.facebook.com https://graph.facebook.com https://*.strava.com https://accounts.google.com https://api.line.me https://access.line.me https://*.google-analytics.com https://tdx.transportdata.tw https://*.ridewithgps.com https://api.openweathermap.org https://fonts.googleapis.com https://fonts.gstatic.com; frame-src 'self' https://*.youtube.com https://*.facebook.com https://accounts.google.com https://*.strava.com https://strava-embeds.com https://ridewithgps.com;
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# 首頁 / index — 加入 RFC 8288 Link headers 給 AI Agent 探索用
# describedby：站點語意描述（給 agent 理解內容）
# sitemap：標準 robots/sitemap 關係
# manifest：PWA 應用清單
# api-catalog：公開 API 目錄（RFC 9727）
/
  Link: </llms.txt>; rel="describedby"; type="text/plain", </sitemap.xml>; rel="sitemap"; type="application/xml", </manifest.webmanifest>; rel="manifest"; type="application/manifest+json", </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json"

/index.html
  Link: </llms.txt>; rel="describedby"; type="text/plain", </sitemap.xml>; rel="sitemap"; type="application/xml", </manifest.webmanifest>; rel="manifest"; type="application/manifest+json", </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json"

# 靜態資源長期快取（Vite 會加 hash）
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icon / 字型快取
/*.png
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML / manifest 短期快取
/index.html
  Cache-Control: public, max-age=3600, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate

# Service Worker 不快取
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# api-catalog 給 AI Agent 自動發現用
/.well-known/api-catalog
  Content-Type: application/linkset+json
  Cache-Control: public, max-age=3600

# Agent Skills 索引
/.well-known/agent-skills/index.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# OAuth / OIDC Discovery（無副檔名，需明確指定 type）
/.well-known/openid-configuration
  Content-Type: application/json
  Cache-Control: public, max-age=3600

/.well-known/oauth-authorization-server
  Content-Type: application/json
  Cache-Control: public, max-age=3600

/.well-known/oauth-protected-resource
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# MCP Server Card
/.well-known/mcp/server-card.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# llms.txt 給 AI 解析（純文字 / markdown）
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

# robots.txt 標準型別 + 短快取（內含 Content-Signal）
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
