/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://connect.facebook.net https://accounts.google.com https://static.cloudflareinsights.com https://*.googletagmanager.com https://*.google-analytics.com https://fonts.googleapis.com https://fonts.gstatic.com https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://unpkg.com https://tdx.transportdata.tw https://ridewithgps.com https://strava-embeds.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com https://unpkg.com; font-src https://fonts.gstatic.com https://r2cdn.perplexity.ai; img-src 'self' data: https:; connect-src 'self' https://*.criterium.tw https://*.supabase.co https://*.zeabur.app https://*.facebook.com https://graph.facebook.com https://*.strava.com https://accounts.google.com https://api.line.me https://access.line.me https://*.google-analytics.com https://tdx.transportdata.tw https://*.ridewithgps.com https://api.openweathermap.org; frame-src 'self' https://*.youtube.com https://*.facebook.com https://accounts.google.com https://*.strava.com https://strava-embeds.com https://ridewithgps.com;
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# 靜態資源長期快取（Vite 會加 hash）
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icon / 字型快取
/*.png
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML / manifest 短期快取
/index.html
  Cache-Control: public, max-age=3600, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate

# Service Worker 不快取
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
